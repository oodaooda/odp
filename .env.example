# ODP Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git (it's in .gitignore)

# ── Server ──
ODP_HOST=0.0.0.0
ODP_PORT=8080

# ── Infrastructure ──
ODP_REDIS_URL=redis://localhost:6379/0
ODP_DATABASE_URL=postgresql+asyncpg://odp:odp@localhost:5432/odp

# ── Orchestrator LLM (Anthropic Claude — for decisions/planning) ──
ODP_ORCH_LLM_PROVIDER=anthropic
ODP_ORCH_LLM_API_KEY=sk-ant-REPLACE_ME
ODP_ORCH_LLM_MODEL=claude-sonnet-4-20250514

# ── Agent LLM (OpenAI — for code generation) ──
ODP_AGENT_LLM_PROVIDER=openai
ODP_AGENT_LLM_API_KEY=sk-REPLACE_ME
ODP_AGENT_LLM_MODEL=gpt-4o

# ── Agent Execution ──
ODP_AGENT_TEST_MODE=0
ODP_AGENT_TIMEOUT_S=1200

# ── Auth (optional — leave empty to disable) ──
# ODP_RBAC_ADMIN_TOKENS=your-admin-token-here
# ODP_RBAC_WRITE_TOKENS=
# ODP_RBAC_READ_TOKENS=

# ── GitHub Integration (optional) ──
# ODP_GITHUB_TOKEN=ghp_REPLACE_ME
# ODP_GITHUB_WEBHOOK_SECRET=your-webhook-secret
# ODP_GITHUB_AUTO_PR=0
# ODP_GITHUB_STATUS_CHECKS=0

# ── Rate Limiting ──
ODP_RATE_LIMIT_WRITE=60
ODP_RATE_LIMIT_READ=300

# ── Logging ──
ODP_LOG_REQUESTS=0
